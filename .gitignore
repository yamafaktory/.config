# Blacklist files/folders in same directory as the .gitignore file.
/*

# Whitelist some files.
!.gitignore

!atuin/
atuin/*
!atuin/config.toml

!bat/
bat/*
!bat/config

!fish/
fish/*
!fish/config.fish

!ghostty/
ghostty/*
!ghostty/config

!niri/
niri/*
!niri/config.kdl
!niri/noctalia.kdl

!noctalia

!nvim/
nvim/*
!nvim/init.lua
!nvim/lazy-lock.json
